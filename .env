# ============================================
# AllinONE 环境变量配置
# ============================================

# ============================================
# 数据库配置（PostgreSQL）
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=allinone_db
DB_USER=postgres
DB_PASSWORD=allinone
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ============================================
# 后端 API 配置
# ============================================
PORT=3000
NODE_ENV=development
API_BASE_URL=http://localhost:3000/api

# JWT 密钥（用于生成认证 token，请使用随机字符串）
JWT_SECRET=allinone-secret-key-2026-change-in-production
JWT_EXPIRES_IN=7d

# ============================================
# 前端配置
# ============================================
VITE_API_BASE_URL=http://localhost:3000/api
VITE_ALLINONE_SYNC_MODE=real

# New Day 游戏配置
VITE_NEWDAY_API_URL=https://yxp6y2qgnh.coze.site/api/allinone

# ============================================
# CloudBase 配置（用于 AI 功能）
# ============================================
# ⚠️ 重要：请替换为真实的 CloudBase 环境 ID
# 从 CloudBase 控制台 (https://console.cloud.tencent.com/tcb) 获取
# 格式类似：allinone-gaming-xxx
VITE_CLOUDBASE_ENV=
# CloudBase Access Key（可选，从 CloudBase 控制台获取 Publishable Key）
VITE_CLOUDBASE_ACCESS_KEY=

# ============================================
# CORS 配置（允许的域名）
# ============================================
CORS_ORIGIN=http://localhost:3000,https://yxp6y2qgnh.coze.site

# ============================================
# 同步配置
# ============================================
SYNC_INTERVAL_MS=30000
SYNC_TIMEOUT_MS=10000
SYNC_RETRY_COUNT=3
